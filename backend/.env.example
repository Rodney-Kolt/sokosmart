# Copy this file to .env and fill in your values

# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase SERVICE ROLE key (from Project Settings > API – keep secret!)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# Brevo SMTP – for OTP email delivery
# Get credentials from: Brevo → SMTP & API → SMTP tab
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_login_email@example.com
BREVO_SMTP_PASS=your_brevo_smtp_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Sokoni Smart
