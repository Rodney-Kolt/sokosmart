# Copy this file to .env and fill in your values

# Google Gemini API key (kept for reference — now replaced by DeepSeek)
# GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API key — replaces Gemini for the AI assistant
# Get from: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase SERVICE ROLE key (from Project Settings > API – keep secret!)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# Brevo Transactional Email API – for OTP email delivery (no IP restrictions)
# Get your API key from: Brevo → SMTP & API → API Keys tab → Create a new API key
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=sokoni@nenlink.online
BREVO_SENDER_NAME=Sokoni Smart

# SMTP credentials kept for reference but no longer used by the backend
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_USER=your_brevo_smtp_login@smtp-brevo.com
# BREVO_SMTP_PASS=your_brevo_smtp_key_here

# Africala SMS – for phone OTP delivery (Uganda +256)
# Get your token from: africala.com → API Settings
# NOTE: Replaced by MessageCentral CPaaS — kept for reference only
# AFRICALA_API_TOKEN=your_africala_api_token_here
# AFRICALA_SENDER_ID=SOKONI

# MessageCentral CPaaS – for phone OTP delivery via Supabase Send SMS Hook
# Get credentials from: cpaas.messagecentral.com → API Settings
MESSAGECENTRAL_API_KEY=your_messagecentral_api_key_here
MESSAGECENTRAL_CUSTOMER_ID=your_messagecentral_customer_id_here
MESSAGECENTRAL_SENDER_ID=SOKONI   # optional – omit if alphanumeric sender not yet approved

# Supabase SMS Hook shared secret – set the same value in Supabase → Auth → Hooks
SMS_HOOK_SECRET=your_random_secret_here

# Your Render backend URL (used as Africala callback URL)
RENDER_EXTERNAL_URL=https://your-backend.onrender.com
