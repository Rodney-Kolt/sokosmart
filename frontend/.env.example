# Copy this file to .env and fill in your values

# Your FastAPI backend URL (Render deployment URL or localhost for dev)
VITE_API_URL=https://your-sokoni-backend.onrender.com

# Supabase project URL (from Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase ANON (public) key – safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
